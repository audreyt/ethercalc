# Compatibility mirror of the authoritative negative `files` entries in
# package.json. npm 11 does not let a root .npmignore override directories
# explicitly allowed by `files`, so release safety comes from package.json and
# is verified with `npm pack --dry-run`.

# Test suites and fixtures (packages keep sources under src/ and tests under
# test/ or tests/ — only runtime sources belong in the npm tarball).
packages/*/test/
packages/*/tests/
packages/*/coverage/
packages/*/.vitest-cache/
packages/*/stryker.conf.json
packages/*/vitest.config.ts
packages/*/vitest.node.config.ts
packages/*/playwright.config.ts

# Oracle harness + e2e are dev-only — they exist purely to validate the
# published worker behavior against the legacy oracle. End users never
# run them; shipping them just bloats the tarball.
packages/oracle-harness/
packages/e2e/

# Build intermediates. The runtime client dist bundles remain intentionally
# published; package.json excludes only cache directories and dist source maps.
packages/*/node_modules/
packages/*/.wrangler/
packages/*/dist/cache/

# Mutation-testing artifacts (see docs/MUTATION_REPORT.md).
reports/
.stryker-tmp/
stryker.log
