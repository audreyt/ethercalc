{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**/packages/**/src/**/*.ts",
			"**/packages/**/src/**/*.tsx",
			"**/packages/**/test/**/*.ts",
			"**/packages/**/test/**/*.tsx",
			"**/scripts/**/*.ts",
			"**/scripts/**/*.js",
			"**/scripts/**/*.sh",
			"!**/packages/socialcalc-headless/**",
			"!**/coverage/**",
			"!**/.stryker-tmp/**"
		]
	},
	"formatter": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "none",
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"noUnreachable": "error"
			},
			"style": {
				"useConst": "error"
			}
		}
	}
}
