{
  "name": "@ethercalc/migrate",
  "version": "0.0.0",
  "private": true,
  "description": "Phase 11b \u2014 Legacy Redis RDB dump \u2192 Cloudflare (DO storage + D1 + KV) migrator (\u00a712)",
