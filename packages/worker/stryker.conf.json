{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Phase 12 mutation testing — see CLAUDE.md §5.3 + docs/MUTATION_REPORT.md. Uses vitest.node.config.ts (Node env, the same config whose 100% line coverage gate we're auditing). `src/index.ts`, `src/env.ts`, and `src/routes/**` (Hono glue) are excluded per §5.2.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest": {
    "configFile": "vitest.node.config.ts"
  },
  "reporters": ["html", "clear-text", "progress", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "mutate": [
    "src/handlers/**/*.ts",
    "src/lib/**/*.ts",
    "src/room.ts"
  ],
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 70
  },
  "timeoutMS": 120000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp"
}
