{
  "name": "@ethercalc/worker",
  "version": "0.0.0",
  "private": true,
  "description": "EtherCalc Worker — Hono HTTP + Durable Object real-time layer",
  "license": "CC0-1.0",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "test": "bun run test:node && bun run test:workers",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:workers": "vitest run",
    "test:coverage": "vitest run --config vitest.node.config.ts --coverage",
    "typecheck": "tsgo --noEmit",
    "build:dry": "wrangler deploy --dry-run",
    "mutation": "stryker run"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@ethercalc/socialcalc-headless": "workspace:*",
    "@ethercalc/socketio-shim": "workspace:*",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@ethercalc/oracle-harness": "workspace:*",
    "@ethercalc/shared": "workspace:*",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
