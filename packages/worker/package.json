{
  "name": "@ethercalc/worker",
  "version": "0.0.0",
  "private": true,
  "description": "EtherCalc Worker — Hono HTTP + Durable Object real-time layer",
  "license": "CC0-1.0",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "vp exec wrangler dev",
    "test": "vp run test:node && vp run test:workers",
    "test:node": "vp test run --config vitest.node.config.ts",
    "test:workers": "vp test run",
    "test:coverage": "vp test run --config vitest.node.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "build:dry": "vp exec wrangler deploy --dry-run",
    "mutation": "vp exec stryker run"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@ethercalc/shared": "workspace:*",
    "@ethercalc/socialcalc-headless": "workspace:*",
    "@ethercalc/socketio-shim": "workspace:*",
    "@simplewebauthn/server": "^13",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@ethercalc/oracle-harness": "workspace:*",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-istanbul": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.107.0"
  }
}
