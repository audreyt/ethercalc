{
  "name": "@ethercalc/client",
  "version": "0.0.0",
  "private": true,
  "description": "EtherCalc single-sheet browser client (Vite + TypeScript)",
  "license": "CC0-1.0",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "mutation": "stryker run"
  },
  "dependencies": {
    "@ethercalc/shared": "workspace:*"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.9.0",
    "@vitest/coverage-istanbul": "^4.1.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.4"
  }
}
