{
  "name": "@ethercalc/client",
  "version": "0.0.0",
  "private": true,
  "description": "EtherCalc single-sheet browser client (Vite + TypeScript)",
  "license": "CC0-1.0",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "build": "vp build && vp exec vite build --config vite.passkey.config.ts",
    "build:passkey": "vp exec vite build --config vite.passkey.config.ts",
    "dev": "vp dev",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "typecheck": "tsc --noEmit",
    "mutation": "vp exec stryker run"
  },
  "dependencies": {
    "@ethercalc/shared": "workspace:*",
    "@m3e/icons": "^1.0.8",
    "@m3e/web": "^2.5.14",
    "dompurify": "^3.4.9",
    "lit": "^3.3.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.9.0",
    "@vitest/coverage-istanbul": "catalog:",
    "jsdom": "^29.1.1",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
