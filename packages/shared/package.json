{
  "name": "@ethercalc/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared contracts between client, worker, and oracle harness",
  "license": "CC0-1.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./messages": "./src/messages.ts",
    "./storage-keys": "./src/storage-keys.ts",
    "./oracle-scenarios": "./src/oracle-scenarios.ts"
  },
  "scripts": {
