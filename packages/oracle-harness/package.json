{
  "name": "@ethercalc/oracle-harness",
  "version": "0.0.0",
  "private": true,
  "description": "Oracle recorder/replayer \u2014 captures the current main branch's HTTP/WS responses so the TypeScript rewrite can be proven equivalent.",
  "license": "CC0-1.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./matchers": "./src/matchers.ts",
    "./record": "./src/record.ts",
    "./replay": "./src/replay.ts"
  },
  "scripts": {
    "record": "bun run src/bin.ts record",
    "replay": "bun run src/bin.ts replay",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "mutation": "stryker run"
  },
  "dependencies": {
    "@ethercalc/shared": "workspace:*",
    "fflate": "^0.8.2",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.9.0",
    "@vitest/coverage-istanbul": "^4.1.4",
    "vitest": "^4.1.4"
  }
}
