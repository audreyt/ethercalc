{
  "name": "@ethercalc/oracle-harness",
  "version": "0.0.0",
  "private": true,
  "description": "Oracle recorder/replayer — captures the current main branch's HTTP/WS responses so the TypeScript rewrite can be proven equivalent.",
  "license": "CC0-1.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./matchers": "./src/matchers.ts",
    "./record": "./src/record.ts",
    "./replay": "./src/replay.ts"
  },
  "scripts": {
    "record": "bun src/bin.ts record",
    "replay": "bun src/bin.ts replay",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "typecheck": "tsc --noEmit",
    "mutation": "vp exec stryker run"
  },
  "dependencies": {
    "@ethercalc/shared": "workspace:*",
    "@ethercalc/socketio-shim": "workspace:*",
    "fflate": "^0.8.2",
    "linkedom": "^0.18.12",
    "socket.io-client": "1.0.6"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.9.0",
    "@vitest/coverage-istanbul": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
