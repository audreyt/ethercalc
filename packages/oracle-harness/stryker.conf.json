{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Phase 12 mutation testing — see CLAUDE.md §5.3 + docs/MUTATION_REPORT.md. bin.ts, cli.ts and record/replay are thin glue with integration coverage, not unit tests, so they're excluded.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest_comment": "Stryker's vitest runner auto-detects vitest.config.ts from cwd.",
  "reporters": ["html", "clear-text", "progress", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "mutate": [
    "src/**/*.ts",
    "!src/index.ts",
    "!src/bin.ts",
    "!src/cli.ts",
    "!src/record.ts",
    "!src/replay.ts"
  ],
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 70
  },
  "timeoutMS": 120000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp"
}
