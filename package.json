{
  "name": "ethercalc",
  "version": "0.20260619.0",
  "description": "Multi-User Spreadsheet Server — TypeScript rewrite (Cloudflare fullstack)",
  "homepage": "http://ethercalc.net/",
  "author": "Audrey Tang <audreyt@audreyt.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audreyt/ethercalc.git"
  },
  "license": "CC0-1.0",
  "keywords": [
    "ethercalc",
    "spreadsheet",
    "collaboration",
    "realtime",
    "cloudflare",
    "workers",
    "hono",
    "durable-objects",
    "socialcalc"
  ],
  "bin": {
    "ethercalc": "bin/ethercalc"
  },
  "files": [
    "bin/",
    "packages/",
    "scripts/",
    "deploy/",
    "static/",
    "images/",
    "l10n/",
    "third-party/",
    "app-graphics/",
    "migrations/",
    "Dockerfile",
    "docker-compose.yml",
    "docker-compose.proxy.yml",
    "*.html",
    "*.ico",
    "*.png",
    "*.svg",
    "*.xml",
    "manifest.json",
    "manifest.appcache",
    "README.md",
    "AGENTS.md",
    "API.md",
    "Changes.txt",
    "!**/node_modules",
    "!**/coverage",
    "!**/reports",
    "!**/.stryker-tmp",
    "!**/test-results",
    "!**/playwright-report",
    "!**/.dev.vars",
    "!**/dist/**/*.map"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "pretest": "bun run build:assets",
    "test": "bun test scripts/build-assets.test.ts && npm run --workspaces --if-present test",
    "build:clients": "bun run --cwd packages/client build && bun run --cwd packages/client-multi build",
    "build:assets": "bun run build:clients && bun run scripts/build-assets.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "mutation": "bun run --filter '*' mutation"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "wrangler": "^4.107.0"
  }
}
