{
  "scenario": {
    "name": "ws/ask-ecell",
    "kind": "ws",
    "steps": [
      {
        "type": "http",
        "request": {
          "method": "PUT",
          "path": "/_/oracle-phase3-ws",
          "headers": {
            "Content-Type": "text/x-socialcalc; charset=utf-8"
          },
          "bodyBase64": ""
        },
        "expect": {
          "status": 201,
          "headers": {
            "content-length": "2",
            "content-type": "text/plain; charset=utf-8"
          },
          "bodyBase64": "T0s=",
          "bodyMatcher": "exact"
        }
      },
      {
        "type": "connect",
        "id": "a",
        "url": "/_ws/oracle-phase3-ws?user=oracle-harness&auth=harness"
      },
      {
        "type": "connect",
        "id": "b",
        "url": "/_ws/oracle-phase3-ws?user=oracle-harness-peer&auth=harness"
      },
      {
        "type": "send",
        "id": "b",
        "msg": {
          "type": "ask.log",
          "room": "oracle-phase3-ws",
          "user": "oracle-harness-peer"
        }
      },
      {
        "type": "expect",
        "id": "b",
        "msg": {
          "type": "log",
          "room": "oracle-phase3-ws",
          "log": [],
          "chat": [],
          "snapshot": "re:.*"
        },
        "match": "partial"
      },
      {
        "type": "sleep",
        "ms": 50
      },
      {
        "type": "send",
        "id": "a",
        "msg": {
          "type": "ask.ecell",
          "room": "oracle-phase3-ws",
          "user": "oracle-harness"
        }
      },
      {
        "type": "expect",
        "id": "b",
        "msg": {
          "type": "ask.ecell",
          "room": "oracle-phase3-ws",
          "user": "oracle-harness"
        },
        "match": "partial"
      },
      {
        "type": "close",
        "id": "a"
      },
      {
        "type": "close",
        "id": "b"
      }
    ]
  }
}
