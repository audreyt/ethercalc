{
  "scenario": {
    "name": "ws/execute-command",
    "kind": "ws",
    "steps": [
      {
        "type": "http",
        "request": {
          "method": "PUT",
          "path": "/_/oracle-phase3-ws",
          "headers": {
            "Content-Type": "text/x-socialcalc; charset=utf-8"
          },
          "bodyBase64": ""
        },
        "expect": {
          "status": 201,
          "headers": {
            "content-length": "2",
            "content-type": "text/plain; charset=utf-8"
          },
          "bodyBase64": "T0s=",
          "bodyMatcher": "exact"
        }
      },
      {
        "type": "connect",
        "url": "/_ws/oracle-phase3-ws?user=oracle-harness&auth=harness"
      },
      {
        "type": "send",
        "msg": {
          "type": "execute",
          "room": "oracle-phase3-ws",
          "user": "oracle-harness",
          "auth": "harness",
          "cmdstr": "set A1 text t ws-phase3"
        }
      },
      {
        "type": "sleep",
        "ms": 50
      },
      {
        "type": "send",
        "msg": {
          "type": "ask.log",
          "room": "oracle-phase3-ws",
          "user": "oracle-harness"
        }
      },
      {
        "type": "expect",
        "msg": {
          "type": "log",
          "room": "oracle-phase3-ws",
          "log": [],
          "chat": [],
          "snapshot": "re:.*oracle.*"
        },
        "match": "partial"
      },
      {
        "type": "close"
      }
    ]
  }
}
