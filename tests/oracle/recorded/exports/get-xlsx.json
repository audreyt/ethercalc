{
  "scenario": {
    "name": "exports/get-xlsx",
    "kind": "http",
    "request": {
      "method": "GET",
      "path": "/_/oracle-phase3-export/xlsx"
    },
    "expect": {
      "status": 200,
      "headers": {
        "content-length": "re:^\\d+$",
        "content-type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      },
      "bodyBase64": "",
      "bodyMatcher": "xlsx"
    }
  }
}
